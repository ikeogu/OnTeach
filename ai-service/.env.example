# Shared JWT secret — must match Laravel SESSION_JWT_SECRET exactly
SESSION_JWT_SECRET=

# Laravel backend internal URL (Railway private network)
LARAVEL_INTERNAL_URL=http://onteach-backend:80

# Qdrant Cloud or self-hosted
QDRANT_URL=https://YOUR_CLUSTER.qdrant.io:6333
QDRANT_API_KEY=

# Redis (Railway add-on or Upstash)
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
HEYGEN_API_KEY=

# S3 / Cloudflare R2 (same bucket as Laravel)
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=onteach-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
