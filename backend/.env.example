APP_NAME=OnTeach
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.onteach.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Database (Railway MySQL add-on sets DATABASE_URL automatically) ──────────
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=onteach
DB_USERNAME=
DB_PASSWORD=

# ── Redis (Railway Redis add-on sets REDIS_URL automatically) ────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_URL=

# ── File Storage (Cloudflare R2 or AWS S3) ───────────────────────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=onteach-uploads
# Cloudflare R2 endpoint: https://<account-id>.r2.cloudflarestorage.com
# Leave empty for standard AWS S3
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@onteach.app"
MAIL_FROM_NAME="${APP_NAME}"

# ── Auth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.onteach.app/api/auth/google/callback

# ── AI Service (internal Railway private network URL) ────────────────────────
AI_SERVICE_URL=http://onteach-ai:8001
AI_SERVICE_WS_URL=wss://YOUR_AI_SERVICE.railway.app

# Shared JWT secret — must be at least 64 hex chars (openssl rand -hex 32)
SESSION_JWT_SECRET=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your Vercel frontend URL
FRONTEND_URL=https://onteach.vercel.app
